# --- Hermes VPS connection ---
HERMES_API_URL=https://your-vps-hostname.tailnet.ts.net/v1/chat/completions
HERMES_API_KEY=changeme
HERMES_MODEL=hermes-3-llama-3.1-8b

# --- Hub bind IP (Tailscale/mesh IP or 127.0.0.1 for local-only) ---
HUB_BIND_IP=127.0.0.1

# --- hermes-ears (STT) ---
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- hermes-mouth (TTS) ---
PIPER_VOICE=en_US-lessac-medium

# --- Honcho memory (self-hosted on another VM) ---
HONCHO_URL=http://honcho-vm.tailnet.ts.net:8000
HONCHO_API_KEY=
HONCHO_WORKSPACE_ID=hermes-satellite
HONCHO_USER_ID=appuser
HONCHO_ASSISTANT_ID=hermes
HONCHO_CONTEXT_TOKENS=4000

# --- satellite (set per-Pi, not on the hub) ---
BRIDGE_URL=http://hub.tailnet.ts.net:18000/satellite/utterance
WAKE_MODEL=hey_jarvis
SATELLITE_ID=satellite-livingroom
